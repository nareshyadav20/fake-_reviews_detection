# API CONFIGURATION

# 1. LOCAL DEVELOPMENT
# Keep this active while working on your computer.
# Ensure your backend is running on port 5001.
REACT_APP_API_URL=http://localhost:5001

# 2. PRODUCTION (RENDER)
# DO NOT uncomment this here. 
# Instead, set this value in your VERCEL dashboard under Settings > Environment Variables.
# REACT_APP_API_URL=https://fake-reviews-detection-o8vo.onrender.com